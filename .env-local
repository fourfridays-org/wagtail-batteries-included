# Please take care that you do not inadvertently commit any configuration secrets
DATABASE_URL=postgres://postgres@postgres:5432/db
DEFAULT_STORAGE_DSN=file:///data/media/?url=%2Fmedia%2F
DJANGO_DEBUG=True
DOMAIN_ALIASES=localhost, 127.0.0.1
SECURE_SSL_REDIRECT=False
WAGTAIL_SITE_NAME=yourwebsitename
EMAIL_BACKEND = your_email_backend
EMAIL_API_KEY=add-your-email-api-key
EMAIL_SENDER_DOMAIN=your.email.domain
DEFAULT_FROM_EMAIL=your@default.email
COMMENT_ADMIN_EMAIL=your@admin.email
SERVER_EMAIL=your@support.email
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret